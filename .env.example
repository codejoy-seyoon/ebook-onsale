# ─── Cafe24 App (개발자센터 > App 관리 > C-Coaching Fulfillment) ───
CAFE24_MALL_ID=bnikorea88
CAFE24_CLIENT_ID=여기에_Client_ID
CAFE24_CLIENT_SECRET=여기에_Client_Secret
# 배포 후 실제 Vercel 도메인으로 맞춰야 함 (Cafe24 Redirect URI와 100% 일치)
CAFE24_REDIRECT_URI=https://ebook-onsale.vercel.app/api/oauth/callback
# 개발자센터 > 인증정보(이벤트 수신)에 표시된 UUID (웹훅 보조 검증용)
CAFE24_WEBHOOK_SECRET=여기에_Webhook_인증정보_UUID
# Admin API 버전 (고정 권장). 최신: 2026-03-01
CAFE24_API_VERSION=2026-03-01

# ─── 이메일 발송 (hq@joy-bnikorea.com / Gmail SMTP) ───
# Gmail 2단계인증 켠 뒤 "앱 비밀번호"를 발급해 넣으세요 (일반 로그인 비번 아님)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=hq@joy-bnikorea.com
MAIL_PASS=구글_앱비밀번호_16자리
MAIL_FROM=C Coaching <hq@joy-bnikorea.com>

# ─── 발송할 이북 PDF ───
# [권장] Vercel Blob(비공개)에 올린 파일의 pathname. mailer 가 get(pathname,{access:'private'}) 로 읽음.
#  주의: 대시보드의 임시 "서명 URL"(vercel-blob-valid-until=...)이 아니라, 파일 "이름(경로)"을 넣으세요.
PDF_BLOB_PATHNAME=ebook.pdf
# [대체] 공개/직접다운로드 URL 을 쓸 경우에만. (PDF_BLOB_PATHNAME 가 있으면 이건 무시됨)
# PDF_SOURCE_URL=https://.../ebook.pdf
# PDF에 열람 비밀번호를 걸었다면 그 비번(메일 본문에 안내됨). 안 걸었으면 비워두세요.
PDF_PASSWORD=

# ─── Vercel Blob 토큰 ───
# Blob 스토어를 프로젝트에 연결하면 Vercel 이 자동 주입합니다. 로컬 실행 시에만 직접 입력.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── 토큰/발송기록 저장소 ───
# 별도 스토어 불필요. 이미 연결된 Vercel Blob(BLOB_STORE_ID)을 그대로 사용합니다.
# (OAuth 토큰: cafe24/tokens.json, 발송기록: cafe24/sent/<order_id>)
